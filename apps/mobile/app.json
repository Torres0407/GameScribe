{
  "expo": {
    "name": "GameScribe",
    "slug": "gamescribe",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gamescribe.app"
    },
    "android": {
      "package": "com.gamescribe.app"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "gamescribe"
  }
}
